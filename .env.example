# ─────────────────────────────────────────────────
# Mise — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# On Vercel: add these in Project → Settings → Environment Variables

# ── REQUIRED ──────────────────────────────────────
# Your OpenAI API key — get it from platform.openai.com
# Used for: Whisper (voice transcription) + GPT-4o (meal generation + receipt scan)
OPENAI_API_KEY=sk-...

# Anthropic API key — get it from console.anthropic.com
# Used for: inbound-email webhook (receipt parser) via Claude claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-...

# ── GMAIL OAUTH (Connect Gmail feature) ──────────
# Steps:
#  1. Go to console.cloud.google.com → New Project
#  2. APIs & Services → Library → enable "Gmail API"
#  3. APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
#  4. Add Authorized JavaScript origins:
#       https://mise-lac.vercel.app
#       http://localhost:3000
#  5. Copy the Client ID below (looks like 123456-abc.apps.googleusercontent.com)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── WEB PUSH NOTIFICATIONS ────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:hello@freshnudge.app

# ── OPTIONAL (for future features) ───────────────
# Supabase (add when you want multi-device sync + auth)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON=eyJhb...
# SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# Stripe (add when you want real payment processing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
